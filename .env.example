# CoverPath — Insurance Operations Platform

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/coverpath?schema=public"

# Auth (NextAuth.js v5)
AUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Google OAuth (optional — leave blank to disable)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# OAuth self-signup — disabled by default; only pre-provisioned users may sign in via Google
ALLOW_OAUTH_SELF_SIGNUP="false"

# Transactional email (Resend) — required for password reset in production
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=""
EMAIL_FROM="notifications@coverpath.io"
# Log reset links to console in development only (never in production)
LOG_RESET_TOKENS="false"

# Site / SEO
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="CoverPath"
NEXT_PUBLIC_SITE_TAGLINE="One platform for the full insurance lifecycle"
NEXT_PUBLIC_OG_IMAGE_URL="/og/default.png"
NEXT_PUBLIC_SUPPORT_EMAIL="support@coverpath.io"
NEXT_PUBLIC_SUPPORT_PHONE="(800) 555-0147"
NEXT_PUBLIC_ORG_LEGAL_NAME="CoverPath Insurance Operations LLC"

# Seed admin password (development only)
SEED_ADMIN_PASSWORD="Admin123!"

# Registration — disabled by default (admin-provisioned users only)
ALLOW_PUBLIC_REGISTRATION="false"
NEXT_PUBLIC_ALLOW_PUBLIC_REGISTRATION="false"

# Health check API key (optional — restricts detailed health response)
HEALTH_CHECK_KEY=""

# Rate limiting — Upstash Redis (required for production on Vercel)
# Create a free database at: https://console.upstash.com/
# Without these keys, rate limiting falls back to in-memory (not durable on serverless)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

## Observability
# Sentry — error tracking & performance (Tier 1)
# Get DSN from: https://sentry.io → Project Settings → Client Keys
# Leave blank to silently disable Sentry
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# PostHog — product analytics & funnels (Tier 1)
# Get key from: https://app.posthog.com → Project Settings
# Leave blank to disable PostHog
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Mixpanel — advanced product analytics (Tier 2, optional)
# Get token from: https://mixpanel.com → Project Settings
# Leave blank for no-op calls (never throws)
NEXT_PUBLIC_MIXPANEL_TOKEN=""

# Datadog — APM & infrastructure (Tier 2, optional)
# Get keys from: https://app.datadoghq.com → Organization Settings → API Keys
# Leave DD_API_KEY blank to skip tracer init
DD_API_KEY=""
DD_APP_KEY=""
DD_SERVICE="coverpath"
DD_ENV="development"

# Vercel Analytics + Speed Insights (Tier 1)
# Zero config — works automatically on Vercel, no-op locally
# No env vars required
